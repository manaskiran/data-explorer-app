# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── SSL ───────────────────────────────────────────────────────────────────────
SSL_KEY_PATH=../ssl/key.pem
SSL_CERT_PATH=../ssl/cert.pem
# SSL_PASSPHRASE=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=data_explorer
PG_USER=postgres
PG_PASSWORD=your_pg_password

# ── Default admin (created on first boot) ─────────────────────────────────────
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=ChangeMe123!

# ── JWT signing secret (generate: openssl rand -base64 64) ───────────────────
JWT_SECRET=replace_with_a_long_random_string_minimum_64_characters_xxxxxxxxxxx

# ── Field-level AES-256 encryption key (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
ENCRYPTION_KEY=replace_with_64_hex_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS (comma-separated) ────────────────────────────────────────────────────
ALLOWED_CORS_ORIGINS=https://localhost:4173,https://YOUR_SERVER_IP:4173

# ── Observability webhook ─────────────────────────────────────────────────────
WEBHOOK_SECRET=your_webhook_secret_here

# ── LLM (OpenAI-compatible) ───────────────────────────────────────────────────
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini
